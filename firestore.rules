rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSuper() {
      return request.auth != null && request.auth.token.email == 'tsk.mons@gmail.com';
    }

    function isGoogle() {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider != 'anonymous';
    }

    function isAllowedOwner() {
      return isGoogle()
        && exists(/databases/$(database)/documents/allowedEmails/$(request.auth.token.email));
    }

    function isStoreAdminEmail(storeId) {
      return isGoogle()
        && exists(/databases/$(database)/documents/storeAdminEmails/$(request.auth.token.email))
        && get(/databases/$(database)/documents/storeAdminEmails/$(request.auth.token.email)).data.storeId == storeId;
    }

    function isOwnerOf(storeId) {
      return isGoogle()
        && request.auth.uid == storeId
        && (
          !exists(/databases/$(database)/documents/stores/$(storeId))
          || get(/databases/$(database)/documents/stores/$(storeId)).data.get('ownerEmail', request.auth.token.email) == request.auth.token.email
        );
    }

    function isStaffOf(storeId) {
      return request.auth != null
        && request.auth.token.firebase.sign_in_provider == 'anonymous'
        && exists(/databases/$(database)/documents/staffSessions/$(request.auth.uid))
        && get(/databases/$(database)/documents/staffSessions/$(request.auth.uid)).data.storeId == storeId;
    }

    function canAccess(storeId) {
      return isSuper() || isOwnerOf(storeId) || isStoreAdminEmail(storeId) || isStaffOf(storeId);
    }

    function canManageStore(storeId) {
      return isSuper() || isOwnerOf(storeId) || isStoreAdminEmail(storeId);
    }

    function staffPermission(storeId, permission, legacyDefault) {
      return isStaffOf(storeId)
        && get(/databases/$(database)/documents/staffSessions/$(request.auth.uid)).data
          .get('permissions', {})
          .get(permission, legacyDefault) == true;
    }

    function canManageMenu(storeId) {
      return canManageStore(storeId) || staffPermission(storeId, 'manageMenu', false);
    }

    function canCloseRegister(storeId) {
      return canManageStore(storeId) || staffPermission(storeId, 'closeRegister', false);
    }

    // 許可メール（オーナーが管理）
    match /allowedEmails/{email} {
      allow read: if isSuper() || (isGoogle() && request.auth.token.email == email);
      allow write: if isSuper();
    }

    match /storeAdminEmails/{email} {
      allow read: if isSuper() || (isGoogle() && request.auth.token.email == email);
      allow write: if isSuper();
    }

    // スタッフセッション（匿名ユーザーを店舗に紐づける）
    match /staffSessions/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create, update: if request.auth != null && request.auth.uid == uid
        && exists(/databases/$(database)/documents/storeCodes/$(request.resource.data.code))
        && get(/databases/$(database)/documents/storeCodes/$(request.resource.data.code)).data.storeId == request.resource.data.storeId;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // 店舗コード
    match /storeCodes/{code} {
      allow read: if request.auth != null;
      allow write: if (isSuper() || isAllowedOwner())
                   && request.resource.data.storeId == request.auth.uid;
    }

    // 店舗
    match /stores/{storeId} {
      allow read: if canAccess(storeId);
      allow create: if isSuper() || isAllowedOwner();
      allow update, delete: if canManageStore(storeId);
    }

    // テーブル（お客さんも読める）
    match /tables/{tableId} {
      allow read: if true;
      allow create: if canAccess(request.resource.data.storeId);
      allow update: if canAccess(resource.data.storeId)
                    || (resource.data.status == 'vacant' && request.resource.data.status == 'occupied');
      allow delete: if canAccess(resource.data.storeId);
    }

    // 席グループ
    match /tableGroups/{groupId} {
      allow read: if canAccess(resource.data.storeId);
      allow create: if canManageStore(request.resource.data.storeId);
      allow update, delete: if canManageStore(resource.data.storeId);
    }

    // カテゴリー（お客さんも読める）
    match /categories/{categoryId} {
      allow read: if true;
      allow create: if canManageMenu(request.resource.data.storeId);
      allow update, delete: if canManageMenu(resource.data.storeId);
    }

    // 商品（お客さんも読める）
    match /products/{productId} {
      allow read: if true;
      allow create: if canManageMenu(request.resource.data.storeId);
      allow update, delete: if canManageMenu(resource.data.storeId);
    }

    // オプションテンプレート
    match /optionTemplates/{templateId} {
      allow read: if canAccess(resource.data.storeId);
      allow create: if canManageMenu(request.resource.data.storeId);
      allow update, delete: if canManageMenu(resource.data.storeId);
    }

    // タグテンプレート
    match /tagTemplates/{templateId} {
      allow read: if canAccess(resource.data.storeId);
      allow create: if canManageMenu(request.resource.data.storeId);
      allow update, delete: if canManageMenu(resource.data.storeId);
    }

    // 注文（お客さんも作成できる）
    match /orders/{orderId} {
      allow read: if true;
      allow create: if true;
      allow update: if canAccess(resource.data.storeId);
      allow delete: if canAccess(resource.data.storeId);
    }

    // 注文アイテム（お客さんも作成できる）
    match /orderItems/{itemId} {
      allow read: if true;
      allow create: if true;
      allow update: if canAccess(resource.data.storeId);
      allow delete: if canAccess(resource.data.storeId);
    }

    // 会計
    match /checks/{checkId} {
      allow read: if canAccess(resource.data.storeId);
      allow create: if canAccess(request.resource.data.storeId);
      allow update, delete: if canAccess(resource.data.storeId);
    }

    // レジ締め
    match /cashClosings/{closingId} {
      allow read: if canCloseRegister(resource.data.storeId);
      allow create: if canCloseRegister(request.resource.data.storeId);
      allow update, delete: if canCloseRegister(resource.data.storeId);
    }

    // スタッフアクション
    match /staffActions/{actionId} {
      allow read: if canAccess(resource.data.storeId);
      allow create: if canAccess(request.resource.data.storeId);
      allow update, delete: if canAccess(resource.data.storeId);
    }

    // 予約
    match /reservations/{reservationId} {
      allow read: if canAccess(resource.data.storeId);
      allow create: if canAccess(request.resource.data.storeId);
      allow update, delete: if canAccess(resource.data.storeId);
    }

    // 店舗設定（お客さんも読める）
    match /storeConfig/{configId} {
      allow read: if true;
      allow write: if isSuper() || isOwnerOf(configId) || isStaffOf(configId);
    }

    // スタッフメンバー
    match /staffMembers/{memberId} {
      allow read: if canAccess(resource.data.storeId);
      allow create: if canManageStore(request.resource.data.storeId);
      allow update, delete: if canManageStore(resource.data.storeId);
    }

    // 呼び出し（お客さんも作成できる）
    match /calls/{callId} {
      allow read: if canAccess(resource.data.storeId);
      allow create: if true;
      allow update: if canAccess(resource.data.storeId);
      allow delete: if canAccess(resource.data.storeId);
    }

    // スタッフトークン
    match /staffTokens/{tokenId} {
      allow read: if canAccess(resource.data.storeId);
      allow create: if canAccess(request.resource.data.storeId);
      allow update, delete: if canAccess(resource.data.storeId);
    }
  }
}
